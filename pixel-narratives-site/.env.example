# CRM webhook for AI Readiness / Deep Dive leads (POST /api/assessment-lead)
CRM_ASSESSMENT_ENDPOINT=
CRM_ASSESSMENT_API_KEY=

# Optional: Deep Dive AI narrative (POST /api/deep-dive-report). If unset, the app uses the deterministic snapshot only (errorCode: openai_disabled).
OPENAI_API_KEY=

# Optional: OpenAI chat model ID. Defaults to gpt-4o-mini when unset (see OPENAI_MODEL in src/app/api/deep-dive-report/route.ts).
OPENAI_MODEL=
